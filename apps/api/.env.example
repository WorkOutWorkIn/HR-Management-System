NODE_ENV=development
PORT=5050
APP_ORIGIN=http://localhost:5173,http://127.0.0.1:5173
API_PREFIX=/api/v1
BODY_LIMIT=1mb
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_LOGIN_RATE_LIMIT_MAX=10
AUTH_FORGOT_PASSWORD_RATE_LIMIT_MAX=5
REQUEST_ID_HEADER_NAME=x-request-id
ALLOW_DEV_AUTH_HEADERS=false
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=secure_hrms
DB_USER=root
DB_PASSWORD=change_me
DB_LOGGING=false
DB_CONNECT_ON_BOOT=false
DB_POOL_MIN=0
DB_POOL_MAX=10
DB_POOL_IDLE_MS=10000
DB_POOL_ACQUIRE_MS=30000
JWT_ACCESS_SECRET=replace-with-strong-secret
JWT_REFRESH_SECRET=replace-with-strong-secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d
BCRYPT_SALT_ROUNDS=12
MAX_FAILED_LOGIN_ATTEMPTS=5
PASSWORD_RESET_TOKEN_TTL_MINUTES=30
FRONTEND_URL=http://localhost:5173
PORTAL_URL=http://localhost:5173/dashboard
MAIL_TRANSPORT=smtp
MAIL_SECURE=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Secure HRMS <no-reply@hrms.local>
